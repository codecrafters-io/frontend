<tr class="border-b border-gray-100 hover:bg-gray-50 group" ...attributes>
  {{! Member column — truncated name with external link icon }}
  <td class="px-4 py-3 max-w-[200px]">
    <a href={{@membership.user.codecraftersProfileUrl}} class="flex items-center group/link" target="_blank" rel="noopener noreferrer">
      <AvatarImage @user={{@membership.user}} class="w-7 h-7 border border-gray-300 rounded-md shadow-xs mr-2 shrink-0" />
      <div class="min-w-0 flex items-center gap-1">
        <span class="text-gray-700 text-sm font-semibold truncate max-w-[130px] inline-block align-middle">
          {{#if @membership.user.githubName}}
            {{@membership.user.githubName}}
          {{else}}
            {{@membership.user.username}}
          {{/if}}
        </span>
        {{#if @membership.isAdmin}}
          <span class="text-gray-400 text-xs shrink-0">(admin)</span>
        {{/if}}
        {{! External link icon }}
        <svg
          class="w-3 h-3 text-gray-400 group-hover/link:text-teal-500 shrink-0 transition-colors"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
          ></path>
        </svg>
      </div>
    </a>
  </td>

  {{! Last Seen column }}
  <td class="px-3 py-3 text-gray-500 text-sm whitespace-nowrap">
    {{#if @membership.lastAttemptAt}}
      {{short-relative-time @membership.lastAttemptAt}}
    {{else}}
      <span class="text-gray-300">&mdash;</span>
    {{/if}}
  </td>

  {{! Joined column }}
  <td class="px-3 py-3 text-gray-500 text-sm whitespace-nowrap">
    {{short-relative-time @membership.createdAt}}
  </td>

  {{! Stages column }}
  <td class="px-3 py-3 text-right text-gray-700 text-sm font-mono">
    {{@membership.numberOfStageAttempts}}
  </td>

  {{! Courses column — scrollable, max ~4 icons wide with fade }}
  <td class="px-3 py-3">
    <div class="relative max-w-[110px]">
      <div class="flex items-center overflow-x-auto no-scrollbar">
        {{#each this.sortedCourses as |course|}}
          <CourseLogo @course={{course}} class="w-5 mr-1 shrink-0" alt="This user started the {{course.name}} challenge." />
        {{/each}}
      </div>
      {{#if this.hasManyCourses}}
        <div class="absolute right-0 top-0 bottom-0 w-6 bg-gradient-to-l from-white group-hover:from-gray-50 pointer-events-none"></div>
      {{/if}}
    </div>
  </td>

  {{! Actions column }}
  <td class="px-3 py-3 text-right">
    {{#unless @membership.isSoleAdmin}}
      {{#if this.isRemoving}}
        <svg class="animate-spin w-4 h-4 text-red-600 inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path
            class="opacity-75"
            fill="currentColor"
            d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
          ></path>
        </svg>
      {{else}}
        {{#if (eq @membership.user this.currentUser)}}
          <button type="button" class="text-gray-400 hover:text-red-600 transition-colors p-1" {{on "click" this.handleLeaveTeamButtonClick}}>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
            <EmberTooltip @text="Leave team" />
          </button>
        {{else if @currentUserIsTeamAdmin}}
          <button
            type="button"
            class="text-gray-400 hover:text-red-600 transition-colors p-1 opacity-0 group-hover:opacity-100"
            {{on "click" this.handleRemoveButtonClick}}
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
            <EmberTooltip @text="Remove member. Their seat can be reassigned to someone else." />
          </button>
        {{/if}}
      {{/if}}
    {{/unless}}
  </td>
</tr>