{{! app/components/live-call-widget/index.hbs }}
{{#if this.liveCallWidget.shouldShowWidget}}
  <div class="fixed bottom-6 right-6 z-50 animate-fade-in" data-test-live-call-widget>
    <div class="w-64 overflow-hidden rounded-sm border border-gray-200 shadow-sm dark:border-white/5 dark:bg-gray-925">
      {{! Header }}
      <div class="flex items-center gap-2.5 border-b border-gray-200 px-3.5 py-3 dark:border-white/5">
        {{#if this.liveCallWidget.displayData.avatar_url}}
          <img
            src={{this.liveCallWidget.displayData.avatar_url}}
            alt={{this.liveCallWidget.displayData.host_name}}
            class="h-7 w-7 rounded-full object-cover"
          />
        {{else}}
          <div class="flex h-7 w-7 items-center justify-center rounded-full bg-teal-500 text-xs font-semibold text-white">
            {{this.hostInitial}}
          </div>
        {{/if}}
        <div class="min-w-0 flex-1">
          <div class="text-xs font-semibold text-gray-950 dark:text-gray-100 truncate">
            {{this.liveCallWidget.displayData.host_name}}
          </div>
          {{#if this.liveCallWidget.displayData.host_title}}
            <div class="text-[10px] text-gray-500 dark:text-gray-500 truncate">
              {{this.liveCallWidget.displayData.host_title}}
            </div>
          {{/if}}
        </div>
        <span class="rounded-sm bg-teal-500/10 px-1.5 py-0.5 text-[9px] font-semibold uppercase tracking-wide text-teal-500">
          Live
        </span>
      </div>
      {{! Body }}
      <div class="px-3.5 py-3">
        <p class="mb-3 text-[11px] leading-relaxed text-gray-600 dark:text-gray-400">
          {{this.liveCallWidget.displayData.cta_text}}
        </p>
        <button
          type="button"
          class="w-full rounded-sm bg-teal-500 px-3 py-2 text-xs font-semibold text-white shadow-xs transition-colors hover:bg-teal-600"
          {{on "click" this.openMeetLink}}
          data-test-live-call-widget-join-button
        >
          {{this.liveCallWidget.displayData.button_text}}
          <span class="ml-1">&rarr;</span>
        </button>
      </div>
    </div>
  </div>
{{/if}}